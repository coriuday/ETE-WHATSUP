# ─────────────────────────────────────────────
# WhatsApp Platform Backend — Environment
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Application
APP_ENV=development         # development | staging | production
APP_NAME="WhatsUp API"
APP_PORT=8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ── Database (Supabase PostgreSQL) ────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Use connection pooling for production (Supabase Pooler):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=20

# ── JWT Authentication ───────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRES_SECS=900       # 15 minutes
JWT_REFRESH_EXPIRES_SECS=2592000  # 30 days

# ── Encryption (AES-256) for credentials ─────
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here-change-this

# ── Meta WhatsApp Business API ───────────────
META_WA_TOKEN=your-meta-whatsapp-business-api-access-token
META_WA_PHONE_NUMBER_ID=your-phone-number-id
META_WA_WABA_ID=your-whatsapp-business-account-id
META_WA_VERIFY_TOKEN=your-webhook-verify-token-set-in-meta-dashboard
META_API_VERSION=v19.0
META_API_BASE_URL=https://graph.facebook.com

# ── Object Storage (MinIO locally, S3 in prod) ─
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=whatsup-media
S3_REGION=ap-south-1
S3_FORCE_PATH_STYLE=true          # true for MinIO, false for AWS S3

# ── Email (SMTP) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="WhatsUp Platform"
SMTP_FROM_EMAIL=noreply@whatsup.dev

# ── n8n Automation ────────────────────────────
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=your-n8n-api-key

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_REQUESTS_PER_MIN=100
RATE_LIMIT_BURST=20

# ── WhatsApp Messaging Limits ─────────────────
WA_MESSAGES_PER_MINUTE=60        # safe default; adjust per approved tier
WA_MESSAGES_PER_SECOND=1

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
