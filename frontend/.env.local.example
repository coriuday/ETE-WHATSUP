# WhatsUp Next.js Frontend Environment Variables

# API Base URL (routed through Nginx proxy locally, or direct to backend port 8080)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Realtime WebSocket URL (for live chat updates)
NEXT_PUBLIC_WS_URL=ws://localhost:8080/api/v1/ws

# App Settings
NEXT_PUBLIC_APP_NAME="WhatsUp Bulk Messenger"
NEXT_PUBLIC_APP_ENV=development
